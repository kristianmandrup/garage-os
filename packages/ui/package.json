{
  "name": "@garageos/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./utils": "./src/utils.ts",
    "./button": "./src/components/button.tsx",
    "./input": "./src/components/input.tsx",
    "./textarea": "./src/components/textarea.tsx",
    "./card": "./src/components/card.tsx",
    "./badge": "./src/components/badge.tsx",
    "./avatar": "./src/components/avatar.tsx",
    "./sheet": "./src/components/sheet.tsx",
    "./tabs": "./src/components/tabs.tsx",
    "./spinner": "./src/components/spinner.tsx",
    "./empty-state": "./src/components/empty-state.tsx",
    "./status-badge": "./src/components/status-badge.tsx",
    "./progress": "./src/components/progress.tsx",
    "./dialog": "./src/components/dialog.tsx",
    "./slider": "./src/components/slider.tsx",
    "./label": "./src/components/label.tsx"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap",
    "typecheck": "tsc --noEmit",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.575.0",
    "tailwind-merge": "^2.2.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.3.6",
    "typescript": "^5.9.3"
  }
}
