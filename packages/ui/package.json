{
  "name": "@garageos/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./tokens": "./src/tokens.ts",
    "./utils": "./src/utils.ts",
    "./button": "./src/components/button.tsx",
    "./input": "./src/components/input.tsx",
    "./textarea": "./src/components/textarea.tsx",
    "./card": "./src/components/card.tsx",
    "./badge": "./src/components/badge.tsx",
    "./avatar": "./src/components/avatar.tsx",
    "./sheet": "./src/components/sheet.tsx",
    "./tabs": "./src/components/tabs.tsx",
    "./spinner": "./src/components/spinner.tsx",
    "./empty-state": "./src/components/empty-state.tsx",
    "./status-badge": "./src/components/status-badge.tsx",
    "./progress": "./src/components/progress.tsx",
    "./dialog": "./src/components/dialog.tsx",
    "./slider": "./src/components/slider.tsx",
    "./label": "./src/components/label.tsx",
    "./dropdown-menu": "./src/components/dropdown-menu.tsx",
    "./toast": "./src/components/toast.tsx",
    "./toaster": "./src/components/toaster.tsx",
    "./tooltip": "./src/components/tooltip.tsx",
    "./skeleton": "./src/components/skeleton.tsx",
    "./breadcrumb": "./src/components/breadcrumb.tsx",
    "./pagination": "./src/components/pagination.tsx",
    "./data-table": "./src/components/data-table.tsx",
    "./form-field": "./src/components/form-field.tsx"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap",
    "typecheck": "tsc --noEmit",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.575.0",
    "tailwind-merge": "^2.2.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.3.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "jsdom": "^29.0.1"
  }
}
